{
  "schemaVersion": 1,
  "availableTargets": [
    "claude",
    "codex",
    "openclaw",
    "cursor"
  ],
  "supportedTargets": [
    "claude",
    "codex",
    "openclaw",
    "cursor"
  ],
  "defaultTargets": [
    "claude",
    "codex"
  ],
  "canonicalRoots": {
    "agents": "canonical/agents",
    "skills": "canonical/skills",
    "runtimeAssets": "canonical/runtime-assets",
    "contracts": "config/contracts",
    "capabilityIndex": "config/capability-index"
  },
  "projectMaterializationPolicy": {
    "defaultAssetMode": "global_reusable_by_default",
    "globalByDefault": [
      "agents",
      "commands",
      "mcp",
      "skills"
    ],
    "projectMaterializationTrigger": "project_specific_customization_or_iteration_innovation",
    "projectRuntimeAssetCopyPolicy": "copy_to_project_when_explicit_project_update_or_project_dedicated_extension",
    "projectAllowedBase": [
      "runtime_entry_context",
      "merged_project_config",
      "project_cache_state",
      "project_evolution_records",
      "project_specific_capability_overrides"
    ],
    "projectStatePaths": [
      ".meta-kim/state",
      ".meta-kim/cache",
      ".meta-kim/backups",
      ".meta-kim/local.overrides.json"
    ],
    "existingProjectProjectionUpdate": {
      "discoveryOrder": [
        "explicit_project_dirs",
        "saved_project_dirs",
        "current_working_directory"
      ],
      "managedStateMarker": ".meta-kim/state/default/project-bootstrap.json",
      "globalDistributionAction": "update_existing_project_projection",
      "projectUpdateStrategy": "project_bootstrap_merge_delta",
      "managedProjectionUpdate": "replace_with_transaction_backup",
      "noManagedProjectAction": "do_not_materialize_project_projection",
      "cleanupMode": "explicit_only"
    },
    "projectCapabilityOwnership": {
      "manifestPath": ".meta-kim/state/default/project-capabilities.json",
      "schemaVersion": "meta-kim-project-capabilities-v0.1",
      "protectedCapabilityTypes": [
        "agent",
        "skill",
        "command"
      ],
      "preserveOwnershipClasses": [
        "runtime_sedimented_project_copy"
      ],
      "preserveDependencyUpdatePolicies": [
        "preserve_project_copy"
      ]
    }
  },
  "generatedTargets": {
    "claude": [
      ".claude/agents",
      ".claude/skills",
      ".claude/settings.json",
      ".mcp.json",
      ".claude/capability-index"
    ],
    "codex": [
      ".codex/agents",
      ".agents/skills",
      ".codex/capability-index",
      ".codex/hooks.json",
      ".codex/commands",
      ".codex/config.toml",
      "codex/config.toml.example"
    ],
    "openclaw": [
      "openclaw/workspaces",
      "openclaw/skills",
      "openclaw/capability-index",
      "openclaw/openclaw.template.json"
    ],
    "cursor": [
      ".cursor/agents",
      ".cursor/skills",
      ".cursor/hooks.json",
      ".cursor/capability-index",
      ".cursor/mcp.json",
      ".cursor/rules"
    ]
  }
}
