{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-kim.dev/contracts/runtime-profile.schema.json",
  "title": "Meta_Kim Runtime Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "label",
    "projection",
    "activation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supportsRepoProjection",
        "supportsLocalActivation",
        "assetTypes",
        "outputPaths",
        "globalAgentProjection",
        "globalAssetOwners"
      ],
      "properties": {
        "supportsRepoProjection": {
          "type": "boolean"
        },
        "supportsLocalActivation": {
          "type": "boolean"
        },
        "assetTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "outputPaths": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "globalAgentProjection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supported",
            "format",
            "renderer",
            "agentsDir",
            "fileExtension",
            "migrationSupport"
          ],
          "properties": {
            "supported": {
              "type": "boolean"
            },
            "format": {
              "type": "string",
              "minLength": 1
            },
            "renderer": {
              "type": "string",
              "minLength": 1
            },
            "agentsDir": {
              "type": ["string", "null"]
            },
            "fileExtension": {
              "type": ["string", "null"]
            },
            "migrationSupport": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "globalAssetOwners": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "enum": [
              "sync-global-meta-theory",
              "sync-runtimes"
            ]
          }
        }
      }
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supportsGlobalSkillSync",
        "supportsGlobalDependencyInstall",
        "supportsGlobalHooks",
        "envKeys",
        "defaultHomeDir"
      ],
      "properties": {
        "supportsGlobalSkillSync": {
          "type": "boolean"
        },
        "supportsGlobalDependencyInstall": {
          "type": "boolean"
        },
        "supportsGlobalHooks": {
          "type": "boolean"
        },
        "envKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "defaultHomeDir": {
          "type": "string"
        }
      }
    }
  }
}
